# crypto-sniping-bot — Environment Variables
# Copy this file to .env and fill in all values marked REQUIRED.
# .env is git-ignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   nano .env   # or your preferred editor

# ── Database ──────────────────────────────────────────────────────────────────
# Strong password for the PostgreSQL database.
SNIPER_DB_PASSWORD=change_me_strong_password     # REQUIRED

# The following are overridden to 'db' / 'disable' by docker-compose.yml
# when running inside Docker. Leave them here for native (non-Docker) runs.
SNIPER_DB_HOST=localhost
SNIPER_DB_PORT=5432
SNIPER_DB_NAME=sniper
SNIPER_DB_USER=sniper
SNIPER_DB_SSL_MODE=disable

# ── Ethereum RPC endpoints ────────────────────────────────────────────────────
ETH_RPC_1=https://mainnet.infura.io/v3/YOUR_KEY   # REQUIRED if trading ETH
ETH_RPC_2=                                         # Optional fallback
ETH_WS_1=wss://mainnet.infura.io/ws/v3/YOUR_KEY   # REQUIRED if trading ETH

# ── BSC RPC endpoints ─────────────────────────────────────────────────────────
BSC_RPC_1=                                         # Optional
BSC_RPC_2=                                         # Optional
BSC_WS_1=                                          # Optional

# ── Solana RPC endpoints (Phase 7) ───────────────────────────────────────────
SOLANA_RPC_HTTP_1=                                 # Optional
SOLANA_WS_1=                                       # Optional

# ── Wallets ───────────────────────────────────────────────────────────────────
SNIPER_WALLET_ADDRESS=0xYOUR_ETHEREUM_WALLET_ADDRESS  # REQUIRED
SNIPER_WALLET_KEY=YOUR_PRIVATE_KEY_HEX_NO_0x_PREFIX   # REQUIRED — keep secret!

# ── Solana keypair (Docker only) ──────────────────────────────────────────────
# Absolute path to the directory on your HOST machine that contains
# solana-wallet-1.json (and any other Solana keypair files).
# This directory is bind-mounted read-only into the container at /keys.
# Only needed if SOLANA_RPC_HTTP_1 is set above.
SOLANA_KEYS_DIR=/home/your_username/.config/sniper/keys

# ── Telegram notifications ────────────────────────────────────────────────────
SNIPER_TELEGRAM_BOT_TOKEN=                         # Optional
SNIPER_TELEGRAM_CHAT_ID=                           # Optional

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info                                     # debug | info | warn | error

# Optional macro throttle — when risk_off, capital sizing halves max position (see shared/config/capital.yaml)
MACRO_REGIME=                                      # unset | risk_off

# ── Solana ingestion delivery ─────────────────────────────────────────────────
# stream (default) | webhook | hybrid — see shared/config/chains.yaml ingestion block
SOLANA_INGESTION_DELIVERY=stream
# Required when delivery=webhook or hybrid with webhook.enabled (never commit the real value)
HELIUS_WEBHOOK_SECRET=

# ── Helius webhook exposure (pick one profile — see docs/guides/HELIUS_WEBHOOK_SETUP.md)
WEBHOOK_PUBLIC_URL=                    # https://sniper.example.com or ngrok URL — for Helius + make webhook-verify
WEBHOOK_DOMAIN=sniper.example.com      # Caddy profile only (DNS A → your static IP)
NGROK_AUTHTOKEN=                       # ngrok profile — https://dashboard.ngrok.com/get-started/your-authtoken
CLOUDFLARE_TUNNEL_TOKEN=               # cloudflared profile — Cloudflare Zero Trust tunnel token
WEBHOOK_EXPOSURE=none                  # none | ngrok | cloudflare | caddy

# ── Operator dashboard (Docker + local dev) ───────────────────────────────────
DASHBOARD_API_KEY=change_me_dashboard_api_key      # auto-generated by `make start` if placeholder
DASHBOARD_PORT=8090
DASHBOARD_UI_PORT=3000
# Comma-separated operator IDs allowed to submit commands via dashboard API
DASHBOARD_ALLOWED_OPERATORS=local-operator
